{
  "name": "converter",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Offline browser-based image converter & compressor. Files never leave your device.",
  "scripts": {
    "dev": "vite --port 5280",
    "build": "vite build",
    "preview": "vite preview --port 5281",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:matrix": "playwright test conversion-matrix.spec.ts && node scripts/generate-matrix-report.mjs",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "jsdom": "^29.0.2",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  }
}
