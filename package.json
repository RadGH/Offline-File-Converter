{
  "name": "converter",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Offline browser-based image converter & compressor. Files never leave your device.",
  "scripts": {
    "dev": "vite --port 5280",
    "prebuild": "node scripts/copy-ort-assets.mjs",
    "build": "vite build",
    "preview": "vite preview --port 5281",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:matrix": "playwright test tests/e2e/conversion-matrix.spec.ts && node scripts/generate-matrix-report.mjs",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/gif.js": "^0.2.5",
    "@types/node": "^22.0.0",
    "@types/upng-js": "^2.1.5",
    "eslint": "^9.0.0",
    "jsdom": "^29.0.2",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "@jsquash/avif": "^2.1.1",
    "@jsquash/jpeg": "^1.6.0",
    "@jsquash/webp": "^1.5.0",
    "gif.js": "^0.2.0",
    "gifenc": "^1.0.3",
    "heic2any": "^0.0.4",
    "jszip": "^3.10.1",
    "mp4-muxer": "^5.2.2",
    "onnxruntime-web": "^1.24.3",
    "upng-js": "^2.1.0"
  }
}
